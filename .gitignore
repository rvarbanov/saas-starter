# See https://help.github.com/articles/ignoring-files/

# Secrets (never commit)
.secret

# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing & coverage
/coverage

# Next.js
/.next/
/out/

# Production
/build
dist

# Vercel
.vercel

# Debug / OS
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# Env: allow committed `.env` (non-secrets); ignore local overrides
.env.local
.env.*.local

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Convex
.convex

# IDE
.idea
.vscode/*
!.vscode/extensions.json

# Playwright
test-results/
playwright-report/
playwright/.cache/
.playwright-mcp/

# Vitest
coverage/

# Optional: generated OpenAPI client
# lib/api/generated
