# -----------------------------------------------------------------------------
# Copy to `.secret` and fill in. This file stays committed; `.secret` is gitignored.
#
# Split reminder:
#   `.env` — public / non-secret (NEXT_PUBLIC_*, WORKOS_CLIENT_ID, Convex URL)
#   `.secret`  — server secrets (API keys, cookie encryption password, optional deploy keys)
# -----------------------------------------------------------------------------

# --- WorkOS AuthKit (required for sign-in / session) ---
WORKOS_API_KEY=replace-me
# Min 32 characters. Generate: openssl rand -base64 24
WORKOS_COOKIE_PASSWORD=replace-me

# WorkOS dashboard → Redirects: set Logout URI to match NEXT_PUBLIC_APP_URL (e.g. http://localhost:3000/)
# so sign-out returns to home. Redirect URI must be http://localhost:3000/callback for local dev.

# --- Playwright E2E (optional — full localhost auth journey in tests/e2e/auth.spec.ts) ---
# Quote passwords that contain # (dotenv treats # as a comment).
# E2E_WORKOS_EMAIL=you@example.com
# E2E_WORKOS_PASSWORD="your-password"

# --- Convex (optional — CI / non-interactive deploy only) ---
# CONVEX_DEPLOY_KEY=replace-me
