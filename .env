# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Convex (public deployment URL; browser + ConvexReactClient) ---
NEXT_PUBLIC_CONVEX_URL=https://incredible-dalmatian-315.convex.cloud

# --- WorkOS AuthKit (public client id + redirect; API key & cookie password in `.secret`) ---
WORKOS_CLIENT_ID=client_01KNG10F437HRA3RYS35FS3133
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback

# --- Playwright E2E (non-secret; read by playwright.config.ts via dotenv) ---
# Values match fallback defaults in playwright.config.ts. For preview/staging E2E, set PLAYWRIGHT_BASE_URL
# to an absolute URL; non-loopback hosts skip the local webServer. Align app URL/OAuth redirects with that origin.
PLAYWRIGHT_BASE_URL=http://localhost:3000
PLAYWRIGHT_TEST_TIMEOUT_MS=60000
PLAYWRIGHT_EXPECT_TIMEOUT_MS=10000
PLAYWRIGHT_NAVIGATION_TIMEOUT_MS=30000
PLAYWRIGHT_ACTION_TIMEOUT_MS=15000
